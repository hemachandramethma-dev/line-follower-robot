#include <micro_ros_arduino.h>
#include <stdio.h>
#include <rcl/rcl.h>
#include <rcl/error_handling.h>
#include <rclc/rclc.h>
#include <rclc/executor.h>
#include <std_msgs/msg/float32.h>
#include <std_msgs/msg/int32_multi_array.h>

// --- Configuration ---
#define AGENT_IP "192.168.1.15" 
#define AGENT_PORT 8888
#define WIFI_SSID "Your_SSID"
#define WIFI_PSK "Your_Password"

// 5-Bit Sensor Pins
constexpr uint8_t SENSOR_PINS[5] = {23, 22, 21, 19, 18};

// Motor Driver Outputs 
constexpr uint8_t PWMA_PIN = 12; constexpr uint8_t AIN1_PIN = 13; constexpr uint8_t AIN2_PIN = 14;   
constexpr uint8_t PWMB_PIN = 25; constexpr uint8_t BIN1_PIN = 26; constexpr uint8_t BIN2_PIN = 27;   
constexpr uint32_t PWM_FREQ = 20000; constexpr uint8_t PWM_RESOLUTION = 8;

// Wheel Encoders 
const int L_ENCA = 32; const int L_ENCB = 33;
const int R_ENCA = 25; const int R_ENCB = 26;
volatile long LencoderCount = 0; volatile long RencoderCount = 0;
int LlastEncoded = 0; int RlastEncoded = 0;

// ROS 2 Communication Handlers
rcl_publisher_t left_state_pub; rcl_publisher_t right_state_pub; rcl_publisher_t sensor_pub;
rcl_subscription_t left_cmd_sub; rcl_subscription_t right_cmd_sub;
std_msgs__msg__Float32 msg_left_state; std_msgs__msg__Float32 msg_right_state;
std_msgs__msg__Int32MultiArray msg_sensors;
std_msgs__msg__Float32 msg_left_cmd; std_msgs__msg__Float32 msg_right_cmd;

rclc_executor_t executor; rclc_support_t support; rcl_allocator_t allocator; rcl_node_t node;

#define RCCHECK(fn) { rcl_ret_t temp_rc = fn; if((temp_rc != RCL_RET_OK)){while(1){delay(100);}}}
#define RCSOFTCHECK(fn) { rcl_ret_t temp_rc = fn; if((temp_rc != RCL_RET_OK)){}}

void IRAM_ATTR update_leftEncoder() {
  int MSB = digitalRead(L_ENCA); int LSB = digitalRead(L_ENCB);
  int encoded = (MSB << 1) | LSB; int sum = (LlastEncoded << 2) | encoded;
  if (sum == 0b1101 || sum == 0b0100 || sum == 0b0010 || sum == 0b1011) LencoderCount--;
  if (sum == 0b1110 || sum == 0b0111 || sum == 0b0001 || sum == 0b1000) LencoderCount++;
  LlastEncoded = encoded;
}
void IRAM_ATTR update_rightEncoder() {
  int MSB = digitalRead(R_ENCA); int LSB = digitalRead(R_ENCB);
  int encoded = (MSB << 1) | LSB; int sum = (RlastEncoded << 2) | encoded;
  if (sum == 0b1101 || sum == 0b0100 || sum == 0b0010 || sum == 0b1011) RencoderCount--;
  if (sum == 0b1110 || sum == 0b0111 || sum == 0b0001 || sum == 0b1000) RencoderCount++;
  RlastEncoded = encoded;
}

void setMotor(uint8_t pwm_pin, uint8_t in1, uint8_t in2, float val) {
  int speed = (int)val;
  if (speed >= 0) {
    digitalWrite(in1, HIGH);   digitalWrite(in2, LOW);
  } else {
    digitalWrite(in1, LOW);    digitalWrite(in2, HIGH);
    speed = -speed;
  }
  ledcWrite(pwm_pin, constrain(speed, 0, 255));
}

void left_cmd_callback(const void * msgin) {
  const std_msgs__msg__Float32 * msg = (const std_msgs__msg__Float32 *)msgin;
  setMotor(PWMA_PIN, AIN1_PIN, AIN2_PIN, msg->data);
}
void right_cmd_callback(const void * msgin) {
  const std_msgs__msg__Float32 * msg = (const std_msgs__msg__Float32 *)msgin;
  setMotor(PWMB_PIN, BIN1_PIN, BIN2_PIN, msg->data);
}

void setup() {
  Serial.begin(115200);
  for(int i=0; i<5; i++) pinMode(SENSOR_PINS[i], INPUT);
  pinMode(AIN1_PIN, OUTPUT); pinMode(AIN2_PIN, OUTPUT); pinMode(BIN1_PIN, OUTPUT); pinMode(BIN2_PIN, OUTPUT);
  ledcAttach(PWMA_PIN, PWM_FREQ, PWM_RESOLUTION); ledcAttach(PWMB_PIN, PWM_FREQ, PWM_RESOLUTION);

  pinMode(L_ENCA, INPUT_PULLUP); pinMode(L_ENCB, INPUT_PULLUP);
  pinMode(R_ENCA, INPUT_PULLUP); pinMode(R_ENCB, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(L_ENCA), update_leftEncoder, CHANGE);
  attachInterrupt(digitalPinToInterrupt(L_ENCB), update_leftEncoder, CHANGE);
  attachInterrupt(digitalPinToInterrupt(R_ENCA), update_rightEncoder, CHANGE);
  attachInterrupt(digitalPinToInterrupt(R_ENCB), update_rightEncoder, CHANGE);

  set_microros_wifi_transports(WIFI_SSID, WIFI_PSK, AGENT_IP, AGENT_PORT);
  delay(2000);

  allocator = rcl_get_default_allocator();
  RCCHECK(rclc_support_init(&support, 0, NULL, &allocator));
  RCCHECK(rclc_node_init_default(&node, "esp32_line_bot", "", &support));

  RCCHECK(rclc_publisher_init_default(&left_state_pub, &node, ROSIDL_GET_MSG_TYPE_SUPPORT(std_msgs, msg, Float32), "/left_wheel_state"));
  RCCHECK(rclc_publisher_init_default(&right_state_pub, &node, ROSIDL_GET_MSG_TYPE_SUPPORT(std_msgs, msg, Float32), "/right_wheel_state"));
  RCCHECK(rclc_publisher_init_default(&sensor_pub, &node, ROSIDL_GET_MSG_TYPE_SUPPORT(std_msgs, msg, Int32MultiArray), "/sensor_readings"));

  RCCHECK(rclc_subscription_init_default(&left_cmd_sub, &node, ROSIDL_GET_MSG_TYPE_SUPPORT(std_msgs, msg, Float32), "/left_wheel_cmd"));
  RCCHECK(rclc_subscription_init_default(&right_cmd_sub, &node, ROSIDL_GET_MSG_TYPE_SUPPORT(std_msgs, msg, Float32), "/right_wheel_cmd"));

  static int32_t memory_buffer[5];
  msg_sensors.data.data = memory_buffer;
  msg_sensors.data.size = 5;
  msg_sensors.data.capacity = 5;

  RCCHECK(rclc_executor_init(&executor, &support.context, 2, &allocator));
  RCCHECK(rclc_executor_add_subscription(&executor, &left_cmd_sub, &msg_left_cmd, &left_cmd_callback, ON_NEW_DATA));
  RCCHECK(rclc_executor_add_subscription(&executor, &right_cmd_sub, &msg_right_cmd, &right_cmd_callback, ON_NEW_DATA));
}

void loop() {
  msg_left_state.data = LencoderCount;
  msg_right_state.data = RencoderCount;
  
  for(int i = 0; i < 5; i++) {
    msg_sensors.data.data[i] = (digitalRead(SENSOR_PINS[i]) == HIGH) ? 1 : 0;
  }

  RCSOFTCHECK(rcl_publish(&left_state_pub, &msg_left_state, NULL));
  RCSOFTCHECK(rcl_publish(&right_state_pub, &msg_right_state, NULL));
  RCSOFTCHECK(rcl_publish(&sensor_pub, &msg_sensors, NULL));

  RCSOFTCHECK(rclc_executor_spin_some(&executor, RCL_MS_TO_NS(10)));
  delay(30);
}
